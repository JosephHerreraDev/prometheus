#!/bin/bash

if [[ -z $1 ]]; then
  echo "Usage: prometheus-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/prometheus/current/theme"
NEXT_THEME_PATH="$HOME/.config/prometheus/current/next-theme"
USER_THEMES_PATH="$HOME/.config/prometheus/themes"
PROMETHEUS_THEMES_PATH="$PROMETHEUS_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d "$PROMETHEUS_THEMES_PATH/$THEME_NAME" ]] && [[ ! -d "$USER_THEMES_PATH/$THEME_NAME" ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

if [[ -d "$PROMETHEUS_THEMES_PATH/$THEME_NAME" ]]; then
  cp -r "$PROMETHEUS_THEMES_PATH/$THEME_NAME/." "$NEXT_THEME_PATH/"
fi

if [[ -d "$USER_THEMES_PATH/$THEME_NAME" ]]; then
  cp -r "$USER_THEMES_PATH/$THEME_NAME/." "$NEXT_THEME_PATH/"
fi

prometheus-theme-set-templates

rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

echo "$THEME_NAME" > "$HOME/.config/prometheus/current/theme.name"

prometheus-theme-bg-next

if pgrep -x waybar >/dev/null; then
  prometheus-restart-waybar
fi

prometheus-restart-swayosd
prometheus-restart-terminal
prometheus-restart-hyprctl
prometheus-restart-btop
prometheus-restart-opencode
prometheus-restart-mako

prometheus-theme-set-gnome
prometheus-theme-set-browser
prometheus-theme-set-vscode
prometheus-theme-set-obsidian
prometheus-theme-set-spotify

prometheus-hook theme-set "$THEME_NAME"