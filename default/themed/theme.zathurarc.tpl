# GENERAL SETTINGS
set window-title-basename true
set statusbar-home-tilde  true
set recolor               true
set selection-clipboard   clipboard

# LAYOUT SETTINGS
set statusbar-h-padding 0
set statusbar-v-padding 0
set show-scrollbars     false

# THEME
set default-bg              "#{{ background_strip }}"
set default-fg              "#{{ foreground_strip }}"
set statusbar-bg            "#{{ background_strip }}"
set statusbar-fg            "#{{ foreground_strip }}"
set inputbar-bg             "#{{ background_strip }}"
set inputbar-fg             "#{{ color2_strip }}"
set completion-bg           "#{{ background_strip }}"
set completion-fg           "#{{ foreground_strip }}"
set completion-group-bg     "#{{ background_strip }}"
set completion-group-fg     "#{{ foreground_strip }}"
set completion-highlight-bg "#{{ color0_strip }}"
set completion-highlight-fg "#{{ foreground_strip }}"
set notification-bg         "#{{ color0_strip }}"
set notification-fg         "#{{ foreground_strip }}"
set notification-error-bg   "#{{ color1_strip }}"
set notification-error-fg   "#{{ foreground_strip }}"
set notification-warning-bg "#{{ color3_strip }}"
set notification-warning-fg "#{{ background_strip }}"
set highlight-color         "#{{ color4_strip }}"
set highlight-active-color  "#{{ accent_strip }}"
set index-bg                "#{{ background_strip }}"
set index-fg                "#{{ foreground_strip }}"
set index-active-bg         "#{{ color0_strip }}"
set index-active-fg         "#{{ foreground_strip }}"
set recolor-darkcolor       "#{{ foreground_strip }}"
set recolor-lightcolor      "#{{ background_strip }}"
set render-loading-bg       "#{{ background_strip }}"
set render-loading-fg       "#{{ foreground_strip }}"
set font                    "Caskaydia Cove Nerd Font"